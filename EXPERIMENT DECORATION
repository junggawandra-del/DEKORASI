local function getGreeting()
    local hour = tonumber(os.date("%H"))
    if hour < 12 then return "Good Morning ☀️"
    elseif hour < 15 then return "Good Afternoon 🌤️"
    elseif hour < 19 then return "Good Evening 🌇"
    else return "Good Night 🌙"
    end
end

local function getInfo()
    return getGreeting() .. "\n" ..
           "📅 Date: " .. os.date("%A, %d %B %Y") .. "\n" ..
           "⏰ Time: " .. os.date("%H:%M:%S") .. "\n" ..
           "🎮 GAME : TOWNSHIP\n" ..
           "👤 DEV : HANZ\n" ..
           "⚙️ MENU : EXPERIMENT DECORATION"
end

local function loadOnline()
    gg.toast("Loading HANZ SECURITY...")
    local url = "https://pastebin.com/raw/gBVqQW2b"
    local content = gg.makeRequest(url)
    if content and content.content then
        load(content.content)()
    else
        gg.alert("Gagal memuat data online!")
    end
end

