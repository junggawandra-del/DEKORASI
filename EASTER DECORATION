local function getHeader()
    local jam = tonumber(os.date("%H"))
    local ucapan = ""
    
    if jam >= 3 and jam < 11 then
        ucapan = "Good Morning ☀️"
    elseif jam >= 11 and jam < 15 then
        ucapan = "Good Afternoon 🌤️"
    elseif jam >= 15 and jam < 19 then
        ucapan = "Good Evening ⛅"
    else
        ucapan = "Good Night 🌙"
    end

    local nama_hari = {Sunday="Minggu", Monday="Senin", Tuesday="Selasa", Wednesday="Rabu", Thursday="Kamis", Friday="Jumat", Saturday="Sabtu"}
    local hari_inggris = os.date("%A")
    local hari_indo = nama_hari[hari_inggris] or hari_inggris
    
    local tanggal = hari_indo .. ", " .. os.date("%d %B %Y")
    local waktu = os.date("%H:%M:%S")
    
    return ucapan .. "\n📅 " .. tanggal .. "\n⏰ " .. waktu .. "\n🎮 GAME : TOWNSHIP\n👨‍💻 DEV : HANZ\n✨ MENU : EASTER DECORATION"
end

