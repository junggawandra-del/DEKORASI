local function kembali()
    gg.toast("🌐 Loading script dari server...")
    local req = gg.makeRequest("https://pastebin.com/raw/gBVqQW2b")
    if req.content then
        local jalankan = load(req.content)
        if jalankan then
            pcall(jalankan)
        else
            gg.alert("❌ Gagal memuat isi script dari server (Syntax Error).")
        end
    else
        gg.alert("❌ Gagal menghubungi Pastebin. Pastikan koneksi internet stabil.")
    end
end

