-- FUNGSI UCAPAN SELAMAT & WAKTU AKURAT
local function getGreeting()
    local hour = tonumber(os.date("%H"))
    if hour >= 5 and hour < 11 then return "Good Morning 🌅"
    elseif hour >= 11 and hour < 15 then return "Good Afternoon ☀️"
    elseif hour >= 15 and hour < 19 then return "Good Evening 🌇"
    else return "Good Night 🌙"
    end
end

-- EFEK LOADING KEREN TEMA BUNGA
local function showLoading()
    for i = 1, 3 do
        gg.toast("🌸 Loading Flower Data... " .. string.rep("✿", i))
        gg.sleep(500)
    end
end

