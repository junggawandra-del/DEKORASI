-- 3. FUNGSI WAKTU & UCAPAN
function getGreeting()
    local hour = tonumber(os.date("%H"))
    if hour >= 5 and hour < 11 then return "🌅 Good Morning"
    elseif hour >= 11 and hour < 15 then return "☀️ Good Afternoon"
    elseif hour >= 15 and hour < 18 then return "🌆 Good Evening"
    else return "🌃 Good Night" end
end

local function SHOW_MENU()
    local date = os.date("%A, %d %B %Y")
    local time = os.date("%H:%M:%S")
    local greeting = getGreeting()
    
    local menu = gg.choice({
        "🔱 1. POSEIDON STATUE",
        "🏛️ 2. RUINS OF ATLANTIS",
        "🏙️ 3. SUNKEN CITY",
        "🏛️ 4. ATLANTIS MUSEUM",
        "🔱 5. ATLANTEAN TRIDEN",
        "🏨 6. ATLANTIS HOTEL",
        "🌿 7. CORAL FENCE",
        "🐚 8. SEA HERALD",
        "🔄 KEMBALI",
        "❌ KELUAR"
    }, nil, greeting .. "\n📅 " .. date .. "\n⏰ " .. time .. "\n🎮 GAME : TOWNSHIP\n👤 DEV : HANZ\n💎 MENU : ATLANTIC DECORATION")

    -- Fix: Jika klik luar atau batal (nil), panggil SHOW_MENU lagi agar tidak keluar
    if menu == nil then 
        gg.setVisible(false)
        while true do
            if gg.isVisible() then
                gg.setVisible(false)
                SHOW_MENU()
                break
            end
        end
    elseif menu == 1 then L1()
    elseif menu == 2 then L2()
    elseif menu == 3 then L3()
    elseif menu == 4 then L4()
    elseif menu == 5 then L5()
    elseif menu == 6 then L6()
    elseif menu == 7 then L7()
    elseif menu == 8 then L8()
    elseif menu == 9 then BACK()
    elseif menu == 10 then EXIT() end
end

