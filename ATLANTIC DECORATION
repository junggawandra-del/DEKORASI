function BACK()
    -- Hanya dipicu saat tombol Kembali/Refresh ditekan
    gg.toast("🔄 Menghubungkan ke Server Online...")
    local re_check = gg.makeRequest(link_akses).content
    if re_check then
        gg.toast("✅ Logic Terupdate!")
        local status, err = pcall(load(re_check))
        if not status then
            gg.alert("Kesalahan Logic Online: " .. tostring(err))
        end
        SHOW_MENU()
    else
        gg.alert("❌ Gagal mengambil data. Cek koneksi!")
        SHOW_MENU()
    end
end

