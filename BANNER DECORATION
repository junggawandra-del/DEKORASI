local function runKembali()
    gg.toast("ЁЯМР Memuat script dari online...")
    gg.sleep(400)

    local status, result = pcall(function()
        return gg.makeRequest("https://pastebin.com/raw/gBVqQW2b")
    end)

    if status and result and result.code == 200 then
        gg.toast("тЬЕ Script online berhasil dimuat!")
        gg.sleep(300)
        local fn, err = load(result.content)
        if fn then
            fn()
        else
            gg.alert("тЭМ Error menjalankan script online:\n" .. tostring(err))
        end
    else
        gg.alert("тЭМ Gagal memuat script dari:\nhttps://pastebin.com/raw/gBVqQW2b\n\nPeriksa koneksi internet.")
    end
end

