local function showMainMenu()
    while true do
        local header = getHeaderInfo()

        local choice = gg.choice(
            {
                "ЁЯН│ 1. COOKING MASTERPIECE",
                "ЁЯОЕ 2. MEETING SANTA",
                "ЁЯОК 3. CONFETTI BLAST",
                "ЁЯФЩ KEMBALI",
                "ЁЯЪк KELUAR",
            },
            nil,
            header
        )

        -- Jika pilihan nil (klik luar / batal) = SEMBUNYIKAN saja, tidak keluar
        if choice == nil then
            gg.setVisible(false)
            -- Tunggu sampai GG terlihat lagi, lalu tampilkan menu kembali
            while not gg.isVisible() do
                gg.sleep(300)
            end
            -- Setelah GG terlihat kembali, tampilkan menu lagi
        elseif choice == 1 then
            runCookingMasterpiece()
        elseif choice == 2 then
            runMeetingSanta()
        elseif choice == 3 then
            runConfettiBlast()
        elseif choice == 4 then
            runKembali()
            -- Setelah kembali, menu tetap berjalan
        elseif choice == 5 then
            -- KELUAR - satu-satunya cara keluar dari menu
            gg.alert("ЁЯСЛ Script dihentikan.\n\nTerima kasih telah menggunakan\nTOWNSHIP SCRIPT by HANZ ЁЯОо")
            os.exit()
        end
    end
end

