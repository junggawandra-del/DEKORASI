-- FUNGSI WAKTU & SALAM
-- ================================================

local function getGreeting()
    local hour = tonumber(os.date("%H"))
    if hour >= 4 and hour < 12 then
        return "ЁЯМЕ Good Morning!"
    elseif hour >= 12 and hour < 15 then
        return "тШАя╕П Good Afternoon!"
    elseif hour >= 15 and hour < 18 then
        return "ЁЯМдя╕П Good Afternoon!"
    elseif hour >= 18 and hour < 21 then
        return "ЁЯМЖ Good Evening!"
    else
        return "ЁЯМЩ Good Night!"
    end
end

local function getDayName()
    local days = {
        "Minggu", "Senin", "Selasa", "Rabu",
        "Kamis", "Jumat", "Sabtu"
    }
    return days[tonumber(os.date("%w")) + 1]
end

local function getMonthName()
    local months = {
        "Januari", "Februari", "Maret", "April",
        "Mei", "Juni", "Juli", "Agustus",
        "September", "Oktober", "November", "Desember"
    }
    return months[tonumber(os.date("%m"))]
end

local function getHeaderInfo()
    local greeting = getGreeting()
    local day = getDayName()
    local date = os.date("%d")
    local month = getMonthName()
    local year = os.date("%Y")
    local time = os.date("%H:%M:%S")

    return greeting .. "\n" ..
           "ЁЯУЕ " .. day .. ", " .. date .. " " .. month .. " " .. year .. "\n" ..
           "ЁЯХР " .. time .. "\n" ..
           "тФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБ\n" ..
           "ЁЯОо GAME   : TOWNSHIP\n" ..
           "ЁЯСитАНЁЯТ╗ DEV    : HANZ\n" ..
           "ЁЯУЛ MENU   : BANNER\n" ..
           "тФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБтФБ"
end

