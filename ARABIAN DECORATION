-- FUNGSI WAKTU & SALAM
function GET_INFO()
    local date = os.date("%A, %d %B %Y")
    local time = os.date("%H:%M:%S")
    local hour = tonumber(os.date("%H"))
    local greeting = ""
    
    if hour >= 5 and hour < 11 then greeting = "Good Morning ☀️"
    elseif hour >= 11 and hour < 15 then greeting = "Good Afternoon 🌤️"
    elseif hour >= 15 and hour < 18 then greeting = "Good Evening ⛅"
    else greeting = "Good Night 🌙" end
    
    return greeting .. "\n📅 " .. date .. "\n⏰ " .. time
end

LOADING()

-- MAIN MENU LOOP
function HOME()
    while true do
        if gg.isVisible(true) then
            gg.setVisible(false)
            
            local info = GET_INFO()
            local menu = gg.choice({
                "1. 🎪 COLORFUL TENT",
                "2. ♟️ CHESS MATCH",
                "3. 🦅 FALCONCRY",
                "4. 💡 MAGIC LAMP",
                "5. 🐎 ARABIC HORSE",
                "🔄 KEMBALI",
                "❌ KELUAR"
            }, nil, info .. "\n\nGAME : TOWNSHIP\nDEV : HANZ\nMENU : ARABIAN DECORATION")

            if menu == 1 then L1() end
            if menu == 2 then L2() end
            if menu == 3 then L3() end
            if menu == 4 then L4() end
            if menu == 5 then L5() end
            if menu == 6 then BACK() end
            if menu == 7 then EXIT() end
        end
        gg.sleep(100)
    end
end

