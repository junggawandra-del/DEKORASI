-- FUNGSI LOADING KEREN
function LOADING()
    local t = {"[ 🟥 ]", "[ 🟧 ]", "[ 🟨 ]", "[ 🟩 ]", "[ 🟦 ]", "[ 🟪 ]"}
    for i = 1, #t do
        gg.toast("Loading " .. t[i] .. " " .. (i * 16) .. "%")
        gg.sleep(150)
    end
end

-- INFO HEADER (JAM, HARI, TANGGAL AKURAT)
function GET_HEADER()
    local time = os.date("%H:%M:%S")
    local date = os.date("%A, %d %B %Y")
    local hour = tonumber(os.date("%H"))
    local greeting = ""

    if hour >= 5 and hour < 11 then greeting = "Good Morning ☀️"
    elseif hour >= 11 and hour < 15 then greeting = "Good Afternoon 🌤️"
    elseif hour >= 15 and hour < 18 then greeting = "Good Evening ⛅"
    else greeting = "Good Night 🌙" end

    return "━━━━━━━━━━━━━━━━━━━━━━━\n" ..
           greeting .. "\n" ..
           "📅 " .. date .. "\n" ..
           "⏰ " .. time .. "\n" ..
           "GAME : TOWNSHIP\n" ..
           "DEV : HANZ\n" ..
           "MENU : EXPEDITION DECORATION\n" ..
           "━━━━━━━━━━━━━━━━━━━━━━━"
end

-- FUNGSI KEMBALI (LOGIKA DARI WEB)
function KEMBALI()
    gg.toast("🔄 Menarik data dari server...")
    local request = gg.makeRequest("https://pastebin.com/raw/gBVqQW2b").content -- Ganti URL GitHub/Pastebin anda
    if request then
        local pcall_status, pcall_err = pcall(load(request))
        if not pcall_status then gg.alert("Gagal memuat script: " .. pcall_err) end
    else
        gg.alert("Koneksi internet bermasalah!")
    end
end

